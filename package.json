{
  "name": "gma3-disco-pilot",
  "version": "0.1.0",
  "description": "AI-driven music genre lighting controller for GrandMA3",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "test:bpm": "node scripts/test-bpm-detection.mjs",
    "setup:models": "npm install --no-save essentia.js && node scripts/model-assets.mjs",
    "check:models": "node scripts/model-assets.mjs check",
    "convert:maest": "node scripts/convert-maest-frozen-model.mjs"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "meyda": "^5.6.2",
    "node-osc": "^9.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.jrikner.gma3-disco-pilot",
    "productName": "GMA3 Disco Pilot",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "GMA3 Disco Pilot needs microphone access to analyze BPM and detect music genre for live lighting automation."
      }
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ]
  }
}
